# ============================================================
# WP SEO Automator — Plantilla de configuración
#
# INSTRUCCIONES:
#   1. Copia este archivo:  copy .env.example .env   (Windows)
#                           cp .env.example .env     (Linux/macOS)
#   2. Completa los valores marcados con <COMPLETAR>
#   3. NUNCA subas .env al repositorio (ya está en .gitignore)
# ============================================================

# ============================================================
# Entorno de ejecución
# Opciones: development | staging | production
# ============================================================
APP_ENV=development

# Host y puerto para uvicorn (solo referencial — uvicorn los recibe como args)
APP_HOST=127.0.0.1
APP_PORT=8000

# DEBUG_MODE=true activa logs verbose. Nunca usar en producción.
DEBUG_MODE=false

# ============================================================
# WordPress Connection
# ============================================================
# URL base de tu WordPress SIN trailing slash
WP_BASE_URL=https://tusitio.com

# Usuario de WordPress con permisos de editor/administrador
WP_API_USER=<COMPLETAR>

# Application Password de WordPress.
# Cómo generarla: WP Admin → Usuarios → Tu perfil → Contraseñas de Aplicación
# → escribe un nombre (ej: "SEO Automator") → clic "Añadir" → copia el valor
# Los espacios son normales y deben mantenerse tal cual.
WP_API_APP_PASSWORD=<COMPLETAR: xxxx xxxx xxxx xxxx>

# ============================================================
# LLM Backend
# Opciones: gemini | ollama | openai_compatible
# ============================================================
LLM_BACKEND=gemini

# --- Gemini ---
# Obtén tu API key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<COMPLETAR: AIzaSy...>
GEMINI_MODEL=gemini-2.0-flash

# --- Ollama (para uso local, sin costo de API) ---
# Descomentar cuando se active en el código
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ============================================================
# Comportamiento
# ============================================================
# SEGURIDAD: Mantener en true hasta que hayas validado el sistema.
# Con true, ningún cambio se publica en WordPress aunque el endpoint
# se llame — el servidor calcula y devuelve el diff pero no publica.
# Para publicar de verdad: enviar dry_run=false en el request body.
DRY_RUN_DEFAULT=true

# ============================================================
# Storage — directorios de backups y logs
# Pueden ser rutas relativas (al root del proyecto) o absolutas.
# ============================================================
BACKUP_DIR=./backups
LOG_DIR=./logs

# Nivel de log. Opciones: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ============================================================
# HTTP / Resilencia
# ============================================================
# Timeout por request a WordPress y Gemini (segundos)
REQUEST_TIMEOUT_SECONDS=30

# Reintentos automáticos ante fallos transitorios del LLM
MAX_RETRIES=3
