# ============================================================
# WordPress Connection
# ============================================================
WP_BASE_URL=https://tusitio.com
WP_API_USER=tu_usuario_wp
# Application Password generada desde WP: Usuarios > Seguridad > Contraseñas de aplicación
WP_API_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================================
# LLM Backend Selection
# Opciones: gemini | ollama | openai_compatible
# ============================================================
LLM_BACKEND=gemini

# Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Ollama (para cuando migremos a IA local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ============================================================
# Behavior
# ============================================================
# Si es true, ningún cambio se publica en WP sin parámetro explícito
DRY_RUN_DEFAULT=true

# ============================================================
# Storage
# ============================================================
BACKUP_DIR=./backups
LOG_DIR=./logs
LOG_LEVEL=INFO

# ============================================================
# HTTP / Resilience
# ============================================================
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
