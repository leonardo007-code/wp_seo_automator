# ============================================================
# Credenciales y configuración local — NUNCA subir al repositorio
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# Entorno virtual Python — se recrea con: pip install -r requirements.txt
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# Datos de runtime — generados en ejecución, no son código
# ============================================================
backups/
logs/

# ============================================================
# Python cache — se regeneran automáticamente
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# ============================================================
# pytest / cobertura
# ============================================================
.pytest_cache/
.coverage
htmlcov/
.cache
coverage.xml
*.cover

# ============================================================
# IDEs y editores
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================
# Distribución y build de Python
# ============================================================
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ============================================================
# mypy / type checking
# ============================================================
.mypy_cache/
.dmypy.json
dmypy.json
